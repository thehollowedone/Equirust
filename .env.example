# Build-time overrides (read at compile time via `option_env!`).
# Rebuild required after changing these.
# Override the host release feed used by the Rust updater.
EQUIRUST_HOST_RELEASES_API_URL=
EQUIRUST_HOST_RELEASES_PAGE_URL=

# Runtime path overrides.
# Point Equirust at a custom Vencord / Equicord runtime dist directory.
EQUIRUST_VENCORD_DIST_DIR=

# Optional custom data directory override.
EQUICORD_USER_DATA_DIR=

# Runtime compatibility / troubleshooting switches.
EQUIRUST_MINIMAL_MOD_RUNTIME=
EQUIRUST_DISABLE_VENCORD_PLUGINS=
EQUIRUST_EDGE_CLIENT_HINTS=
EQUIRUST_CONTROL_RUNTIME=
EQUIRUST_NO_HOST_RUNTIME=
EQUIRUST_NO_MOD_RUNTIME=
EQUIRUST_DISABLE_MANAGED_RUNTIME=

# Optional arRPC backend override path.
EQUIRUST_ARRPC_BINARY=
